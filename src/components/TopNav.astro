---
// Üst gezinme — parşömen çubuk: solda isim, ortada gruplu açılır menü,
// sağda amber iletişim butonu. Mobilde hamburger.
import { withBase } from '../utils/url';

const groups = [
  {
    label: 'Hakkımda',
    items: [
      { href: '/ben-kimim', label: 'Ben Kimim' },
      { href: '/nasil-yazmaya-basladim', label: 'Nasıl Yazmaya Başladım' },
      { href: '/neden-yaziyorum', label: 'Neden Yazıyorum' },
    ],
  },
  {
    label: 'Yazılar',
    items: [
      { href: '/yazdiklarim', label: 'Yazdıklarım' },
      { href: '/okuduklarim', label: 'Okuduklarım' },
      { href: '/dusunduren-sozler', label: 'Düşündüren Sözler' },
    ],
  },
  {
    label: 'Galeri',
    items: [
      { href: '/yazdiran-fotograflar', label: 'Yazdıran Fotoğraflar' },
      { href: '/seyahatler', label: 'Seyahatler' },
      { href: '/idanin-guncesi', label: "Ida'nın Güncesi" },
    ],
  },
];
const blogUrl = 'https://aysegulyilmaz.blogspot.com/';
const email = 'aysyilmaz@gmail.com';
---

<header class="nav" id="site-nav">
  <div class="container nav__inner">
    <a href={withBase('/')} class="nav__brand">Ayşegül Yılmaz</a>

    <button
      class="nav__toggle"
      aria-label="Menüyü aç/kapat"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span></span><span></span><span></span>
    </button>

    <nav class="nav__menu" id="nav-menu" aria-label="Ana menü">
      <ul class="nav__list">
        {
          groups.map((group) => (
            <li class="nav__group">
              <button class="nav__grouplabel" aria-expanded="false">
                {group.label}
                <svg width="10" height="6" viewBox="0 0 11 7" aria-hidden="true">
                  <path d="M1 1l4.5 4L10 1" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </button>
              <ul class="nav__dropdown">
                {group.items.map((item) => (
                  <li>
                    <a href={withBase(item.href)}>{item.label}</a>
                  </li>
                ))}
              </ul>
            </li>
          ))
        }
        <li class="nav__group">
          <a class="nav__grouplabel nav__grouplabel--link" href={blogUrl} target="_blank" rel="noopener">
            Blog ↗
          </a>
        </li>
        <li class="nav__cta-mobile">
          <a class="btn btn--primary" href={`mailto:${email}`}>İletişim →</a>
        </li>
      </ul>
    </nav>

    <a class="btn btn--primary nav__cta" href={`mailto:${email}`}>İletişim →</a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(252, 250, 241, 0.9);
    backdrop-filter: saturate(160%) blur(10px);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid var(--color-bone);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-20);
    height: var(--nav-h);
  }
  .nav__brand {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.011em;
    color: var(--color-ink);
    white-space: nowrap;
  }
  .nav__brand:hover {
    color: var(--color-saddle);
  }

  .nav__menu {
    margin-left: auto;
  }
  .nav__list {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav__group {
    position: relative;
  }
  .nav__grouplabel {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 400;
    color: var(--color-ink);
    background: none;
    border: 0;
    cursor: pointer;
    padding: 9px 14px;
    border-radius: var(--radius-control);
    transition: color 0.15s ease;
  }
  .nav__grouplabel:hover,
  .nav__group:hover .nav__grouplabel {
    color: var(--color-saddle);
  }
  .nav__grouplabel svg {
    transition: transform 0.2s ease;
    color: var(--color-bark);
  }
  .nav__group:hover .nav__grouplabel svg {
    transform: rotate(180deg);
  }

  .nav__dropdown {
    list-style: none;
    margin: 0;
    padding: var(--spacing-8);
    position: absolute;
    top: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%) translateY(6px);
    min-width: 230px;
    background: var(--color-parchment);
    border: 1px solid var(--color-loam);
    border-radius: var(--radius-card);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
  }
  .nav__group:hover .nav__dropdown,
  .nav__group:focus-within .nav__dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
  .nav__dropdown a {
    display: block;
    padding: 9px 12px;
    border-radius: var(--radius-control);
    font-size: var(--text-body);
    color: var(--color-ink);
    white-space: nowrap;
  }
  .nav__dropdown a:hover {
    background: var(--color-bone);
    color: var(--color-ink);
  }

  .nav__cta {
    white-space: nowrap;
  }
  .nav__cta-mobile {
    display: none;
  }

  .nav__toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    background: none;
    border: 0;
    cursor: pointer;
  }
  .nav__toggle span {
    display: block;
    width: 22px;
    height: 2px;
    margin: 0 auto;
    background: var(--color-ink);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .nav.is-open .nav__toggle span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav.is-open .nav__toggle span:nth-child(2) {
    opacity: 0;
  }
  .nav.is-open .nav__toggle span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 880px) {
    .nav__cta {
      display: none;
    }
    .nav__toggle {
      display: flex;
    }
    .nav__menu {
      position: fixed;
      top: var(--nav-h);
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-parchment);
      border-top: 1px solid var(--color-bone);
      padding: var(--spacing-16) 24px var(--spacing-40);
      overflow-y: auto;
      transform: translateX(100%);
      transition: transform 0.3s ease;
    }
    .nav.is-open .nav__menu {
      transform: translateX(0);
    }
    .nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
    }
    .nav__group {
      border-bottom: 1px solid var(--color-bone);
    }
    .nav__grouplabel {
      width: 100%;
      justify-content: space-between;
      padding: 16px 6px;
      font-size: 17px;
    }
    .nav__dropdown {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      border: 0;
      min-width: 0;
      padding: 0 0 10px 10px;
      display: none;
      background: none;
    }
    .nav__group.is-expanded .nav__dropdown {
      display: block;
    }
    .nav__group:hover .nav__grouplabel svg {
      transform: none;
    }
    .nav__group.is-expanded .nav__grouplabel svg {
      transform: rotate(180deg);
    }
    .nav__cta-mobile {
      display: block;
      margin-top: var(--spacing-20);
    }
    .nav__cta-mobile .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  const toggle = nav?.querySelector('.nav__toggle');

  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
  });

  nav?.querySelectorAll('.nav__group').forEach((group) => {
    const label = group.querySelector('.nav__grouplabel');
    if (!label || label.classList.contains('nav__grouplabel--link')) return;
    label.addEventListener('click', (e) => {
      if (window.matchMedia('(max-width: 880px)').matches) {
        e.preventDefault();
        group.classList.toggle('is-expanded');
        const exp = group.classList.contains('is-expanded');
        label.setAttribute('aria-expanded', exp ? 'true' : 'false');
      }
    });
  });
</script>
