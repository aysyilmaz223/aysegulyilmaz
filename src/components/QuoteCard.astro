---
interface Props {
  metin: string;
  kaynak?: string;
}
const { metin, kaynak } = Astro.props;
---

<figure class="quote">
  <blockquote>{metin}</blockquote>
  {kaynak && <figcaption class="meta">— {kaynak}</figcaption>}
</figure>

<style>
  .quote {
    margin: 0;
    border: 1px solid var(--color-pencil-gray);
    padding: var(--spacing-16);
  }
  blockquote {
    margin: 0;
    font-size: var(--text-body);
    line-height: 1.55;
    color: var(--color-ink-black);
  }
  figcaption {
    margin-top: var(--spacing-12);
  }
</style>
