---
// Sabit bio rayı — kimlik, gezinme (renk-ağırlığıyla durum), iletişim, zaman damgası
import { withBase } from '../utils/url';

const groups = [
  {
    label: 'Hakkımda',
    items: [
      { href: '/ben-kimim', label: 'Ben Kimim' },
      { href: '/nasil-yazmaya-basladim', label: 'Nasıl Yazmaya Başladım' },
      { href: '/neden-yaziyorum', label: 'Neden Yazıyorum' },
    ],
  },
  {
    label: 'Yazılar',
    items: [
      { href: '/yazdiklarim', label: 'Yazdıklarım' },
      { href: '/okuduklarim', label: 'Okuduklarım' },
      { href: '/dusunduren-sozler', label: 'Düşündüren Sözler' },
    ],
  },
  {
    label: 'Galeri',
    items: [
      { href: '/yazdiran-fotograflar', label: 'Yazdıran Fotoğraflar' },
      { href: '/seyahatler', label: 'Seyahatler' },
      { href: '/idanin-guncesi', label: "Ida'nın Güncesi" },
    ],
  },
];

const blogUrl = 'https://aysegulyilmaz.blogspot.com/';
const instagram = 'https://www.instagram.com/aysegulyy/';
const email = 'aysyilmaz@gmail.com';

// aktif sayfa tespiti (base yolunu çıkararak)
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
let path = Astro.url.pathname.slice(base.length) || '/';
path = path.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<aside class="sidebar">
  <a href={withBase('/')} class="brand">Ayşegül Yılmaz</a>
  <p class="bio">
    İstanbul. Koç, hikâye anlatıcısı, gezgin. Yazıyor, okuyor, geziyor —
    doğa ve Labrador sevdalısı, Ida’nın annesi. 🐾
  </p>

  <nav class="nav" aria-label="Site gezinmesi">
    {
      groups.map((group) => (
        <div class="nav__group">
          <p class="nav__label">{group.label}</p>
          <ul>
            {group.items.map((item) => (
              <li>
                <a
                  href={withBase(item.href)}
                  class={isActive(item.href) ? 'nav__link is-active' : 'nav__link'}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
    <div class="nav__group">
      <p class="nav__label">Blog</p>
      <ul>
        <li>
          <a class="nav__link" href={blogUrl} target="_blank" rel="noopener">
            Blog ↗
          </a>
        </li>
      </ul>
    </div>
  </nav>

  <div class="contact">
    <a class="contact__link" href={instagram} target="_blank" rel="noopener">
      <span aria-hidden="true" class="glyph">◇</span> Instagram
    </a>
    <a class="contact__link" href={`mailto:${email}`}>
      <span aria-hidden="true" class="glyph">✶</span> {email}
    </a>
  </div>

  <p class="stamp" id="stamp">İSTANBUL</p>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 0;
    align-self: start;
    max-height: 100vh;
    overflow-y: auto;
    padding: var(--spacing-32) var(--spacing-20) var(--spacing-32) clamp(20px, 3vw, 32px);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-20);
  }
  .brand {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-ink-black);
    letter-spacing: -0.01em;
  }
  .bio {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-black);
    margin: 0;
    max-width: 30ch;
  }

  .nav {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-16);
  }
  .nav__group ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .nav__label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-graphite);
    margin: 0 0 6px;
  }
  .nav__link {
    font-size: 13px;
    line-height: 1.45;
    color: var(--color-graphite);
  }
  .nav__link:hover {
    color: var(--color-ink-black);
  }
  .nav__link.is-active {
    color: var(--color-ink-black);
    font-weight: 500;
  }

  .contact {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-8);
  }
  .contact__link {
    font-size: 12px;
    color: var(--color-ink-black);
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-8);
  }
  .contact__link:hover {
    color: var(--color-smoke);
  }
  .glyph {
    font-size: 10px;
    color: var(--color-graphite);
  }

  .stamp {
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--color-graphite);
    margin: 0;
  }

  /* mobil: bio rayı üstte, gezinme yatay sarmalı */
  @media (max-width: 900px) {
    .sidebar {
      position: static;
      max-height: none;
      border-bottom: 1px solid var(--color-pencil-gray);
      padding-bottom: var(--spacing-20);
    }
    .nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--spacing-32);
    }
  }
</style>

<script>
  // sessiz canlı zaman damgası: İSTANBUL HH:MM
  const el = document.getElementById('stamp');
  function tick() {
    if (!el) return;
    const t = new Intl.DateTimeFormat('tr-TR', {
      hour: '2-digit',
      minute: '2-digit',
      timeZone: 'Europe/Istanbul',
    }).format(new Date());
    el.textContent = `İSTANBUL ${t}`;
  }
  tick();
  setInterval(tick, 30000);
</script>
