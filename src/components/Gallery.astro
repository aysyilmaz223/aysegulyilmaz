---
// Responsive foto ızgarası + hafif (vanilla) lightbox.
// items: { src, caption? } listesi
interface Item {
  src: string;
  caption?: string;
}
interface Props {
  items: Item[];
  columns?: number;
}
const { items, columns = 3 } = Astro.props;
---

<div class="gallery" style={`--cols:${columns}`}>
  {
    items.map((item) => (
      <figure class="gallery__item">
        <button class="gallery__btn" data-src={item.src} data-caption={item.caption ?? ''}>
          <img src={item.src} alt={item.caption ?? ''} loading="lazy" />
        </button>
        {item.caption && <figcaption>{item.caption}</figcaption>}
      </figure>
    ))
  }
</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" hidden>
  <button class="lightbox__close" aria-label="Kapat">×</button>
  <figure class="lightbox__fig">
    <img id="lightbox-img" src="" alt="" />
    <figcaption id="lightbox-cap"></figcaption>
  </figure>
</div>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
    gap: 16px;
  }
  .gallery__item {
    margin: 0;
  }
  .gallery__btn {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .gallery__btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .gallery__btn:hover img {
    transform: scale(1.04);
  }
  .gallery figcaption {
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 8px;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(20, 18, 15, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5vw;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox__fig {
    margin: 0;
    max-width: 100%;
    max-height: 100%;
    text-align: center;
  }
  .lightbox__fig img {
    max-width: 100%;
    max-height: 82vh;
    border-radius: 8px;
    margin: 0 auto;
  }
  .lightbox__fig figcaption {
    color: #f4efe9;
    font-size: 0.95rem;
    margin-top: 16px;
  }
  .lightbox__close {
    position: absolute;
    top: 18px;
    right: 26px;
    font-size: 2.4rem;
    line-height: 1;
    color: #fff;
    background: none;
    border: 0;
    cursor: pointer;
  }

  @media (max-width: 820px) {
    .gallery {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .gallery {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lbCap = document.getElementById('lightbox-cap');

  function open(src: string, caption: string) {
    if (!lb || !lbImg || !lbCap) return;
    lbImg.src = src;
    lbImg.alt = caption;
    lbCap.textContent = caption;
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function close() {
    if (!lb) return;
    lb.hidden = true;
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.gallery__btn').forEach((btn) => {
    btn.addEventListener('click', () =>
      open(btn.dataset.src ?? '', btn.dataset.caption ?? '')
    );
  });
  lb?.querySelector('.lightbox__close')?.addEventListener('click', close);
  lb?.addEventListener('click', (e) => {
    if (e.target === lb) close();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
