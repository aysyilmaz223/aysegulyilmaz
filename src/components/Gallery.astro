---
// Masonry foto duvarı + sessiz lightbox. Kenardan kenara, çerçevesiz tiles.
interface Item {
  src: string;
  caption?: string;
}
interface Props {
  items: Item[];
  columns?: number;
}
const { items, columns = 3 } = Astro.props;
---

<div class="wall" style={`--cols:${columns}`}>
  {
    items.map((item) => (
      <figure class="tile">
        <button class="tile__btn" data-src={item.src} data-caption={item.caption ?? ''}>
          <img src={item.src} alt={item.caption ?? ''} loading="lazy" />
        </button>
        {item.caption && <figcaption class="meta">{item.caption}</figcaption>}
      </figure>
    ))
  }
</div>

<div class="lightbox" id="lightbox" hidden>
  <button class="lightbox__close" aria-label="Kapat">×</button>
  <figure class="lightbox__fig">
    <img id="lightbox-img" src="" alt="" />
    <figcaption id="lightbox-cap"></figcaption>
  </figure>
</div>

<style>
  .wall {
    column-count: var(--cols);
    column-gap: var(--spacing-16);
  }
  .tile {
    margin: 0 0 var(--spacing-32);
    break-inside: avoid;
  }
  .tile__btn {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
  }
  .tile__btn img {
    width: 100%;
    height: auto;
    transition: opacity 0.2s ease;
  }
  .tile__btn:hover img {
    opacity: 0.85;
  }
  .tile figcaption {
    margin-top: var(--spacing-8);
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.97);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5vw;
  }
  .lightbox[hidden] {
    display: none;
  }
  .lightbox__fig {
    margin: 0;
    max-width: 100%;
    max-height: 100%;
    text-align: center;
  }
  .lightbox__fig img {
    max-width: 100%;
    max-height: 82vh;
    margin: 0 auto;
  }
  .lightbox__fig figcaption {
    color: var(--color-graphite);
    font-size: var(--text-caption);
    margin-top: var(--spacing-16);
  }
  .lightbox__close {
    position: absolute;
    top: 16px;
    right: 22px;
    font-size: 1.8rem;
    line-height: 1;
    color: var(--color-ink-black);
    background: none;
    border: 0;
    cursor: pointer;
  }

  @media (max-width: 760px) {
    .wall {
      column-count: 2;
    }
  }
  @media (max-width: 460px) {
    .wall {
      column-count: 1;
    }
  }
</style>

<script>
  const lb = document.getElementById('lightbox');
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lbCap = document.getElementById('lightbox-cap');

  function open(src: string, caption: string) {
    if (!lb || !lbImg || !lbCap) return;
    lbImg.src = src;
    lbImg.alt = caption;
    lbCap.textContent = caption;
    lb.hidden = false;
    document.body.style.overflow = 'hidden';
  }
  function close() {
    if (!lb) return;
    lb.hidden = true;
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.tile__btn').forEach((btn) => {
    btn.addEventListener('click', () =>
      open(btn.dataset.src ?? '', btn.dataset.caption ?? '')
    );
  });
  lb?.querySelector('.lightbox__close')?.addEventListener('click', close);
  lb?.addEventListener('click', (e) => {
    if (e.target === lb) close();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
  });
</script>
