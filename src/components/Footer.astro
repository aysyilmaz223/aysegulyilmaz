---
import { withBase } from '../utils/url';
const year = new Date().getFullYear();
const email = 'aysyilmaz@gmail.com';
const instagram = 'https://www.instagram.com/aysegulyy/';
const blog = 'https://aysegulyilmaz.blogspot.com/';

const cols = [
  {
    label: 'Hakkımda',
    items: [
      { href: withBase('/ben-kimim'), label: 'Ben Kimim' },
      { href: withBase('/nasil-yazmaya-basladim'), label: 'Nasıl Yazmaya Başladım' },
      { href: withBase('/neden-yaziyorum'), label: 'Neden Yazıyorum' },
    ],
  },
  {
    label: 'Yazılar',
    items: [
      { href: withBase('/yazdiklarim'), label: 'Yazdıklarım' },
      { href: withBase('/seyahatler'), label: 'Seyahatler' },
      { href: withBase('/idanin-guncesi'), label: "Ida'nın Güncesi" },
    ],
  },
  {
    label: 'Galeri',
    items: [
      { href: withBase('/yazdiran-fotograflar'), label: 'Yazdıran Fotoğraflar' },
      { href: withBase('/dusunduren-sozler'), label: 'Düşündüren Sözler' },
      { href: withBase('/okuduklarim'), label: 'Okuduklarım' },
    ],
  },
  {
    label: 'İletişim',
    items: [
      { href: `mailto:${email}`, label: email, ext: true },
      { href: instagram, label: 'Instagram ↗', ext: true },
      { href: blog, label: 'Blog ↗', ext: true },
      { href: withBase('/gizlilik'), label: 'Gizlilik' },
    ],
  },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__name">Ayşegül Yılmaz</p>
      <p class="footer__tag">
        Koç, hikâye anlatıcısı, gezgin ve Ida’nın annesi. 🐾
      </p>
    </div>

    <div class="footer__cols">
      {
        cols.map((col) => (
          <nav class="footer__col" aria-label={col.label}>
            <p class="footer__coltitle">{col.label}</p>
            <ul>
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    {...(item.ext ? { target: '_blank', rel: 'noopener' } : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>
  </div>
  <div class="container footer__base">
    <span>© {year} Ayşegül Yılmaz</span>
    <span class="footer__legal">
      <a href={withBase('/gizlilik')}>Gizlilik</a>
      <a class="footer__top" href="#icerik">Yukarı ↑</a>
    </span>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bone);
    border-top: 1px solid var(--color-loam);
    margin-top: var(--spacing-120);
  }
  .footer__inner {
    display: grid;
    grid-template-columns: 1.2fr 2.6fr;
    gap: var(--spacing-40);
    padding-top: var(--spacing-60);
    padding-bottom: var(--spacing-40);
  }
  .footer__name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    margin: 0 0 var(--spacing-8);
  }
  .footer__tag {
    margin: 0;
    max-width: 30ch;
    font-size: var(--text-body);
    color: var(--color-saddle);
  }
  .footer__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-20);
  }
  .footer__coltitle {
    font-size: var(--text-caption);
    text-transform: uppercase;
    letter-spacing: 0.107em;
    color: var(--color-bark);
    margin: 0 0 var(--spacing-12);
  }
  .footer__col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-12);
  }
  .footer__col a {
    font-size: var(--text-eyebrow);
    color: var(--color-saddle);
    border-bottom: 1px solid transparent;
    padding-bottom: 1px;
  }
  .footer__col a:hover {
    color: var(--color-ink);
    border-bottom-color: var(--color-loam);
  }
  .footer__base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--spacing-20);
    padding-bottom: var(--spacing-32);
    border-top: 1px solid var(--color-loam);
    font-size: var(--text-eyebrow);
    color: var(--color-bark);
  }
  .footer__legal {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-20);
  }
  .footer__legal a {
    color: var(--color-saddle);
  }
  .footer__legal a:hover {
    color: var(--color-ink);
  }
  .footer__top {
    color: var(--color-saddle);
  }

  @media (max-width: 820px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--spacing-32);
    }
    .footer__cols {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
