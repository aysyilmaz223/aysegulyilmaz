---
interface Props {
  ad: string;
  yazar: string;
  not?: string;
  kapak?: string;
}
const { ad, yazar, not, kapak } = Astro.props;
---

<article class="book">
  <div class="book__cover">
    {
      kapak ? (
        <img src={kapak} alt={`${ad} kapağı`} loading="lazy" />
      ) : (
        <span class="book__placeholder">{ad}</span>
      )
    }
  </div>
  <div class="book__info">
    <h3 class="book__title">{ad}</h3>
    <p class="book__author">{yazar}</p>
    {not && <p class="book__note">{not}</p>}
  </div>
</article>

<style>
  .book {
    display: flex;
    gap: var(--spacing-20);
    padding: var(--spacing-32);
    background: var(--color-pure-white);
    border: 1px solid var(--color-loam);
    border-radius: var(--radius-card);
  }
  .book__cover {
    flex: 0 0 86px;
    width: 86px;
    height: 122px;
    border: 1px solid var(--color-loam);
    border-radius: var(--radius-control);
    background: var(--color-bone);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .book__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .book__placeholder {
    padding: var(--spacing-8);
    font-family: var(--font-display);
    font-size: var(--text-eyebrow);
    color: var(--color-saddle);
  }
  .book__info {
    min-width: 0;
  }
  .book__title {
    font-size: 19px;
    margin: 0 0 2px;
  }
  .book__author {
    margin: 0 0 var(--spacing-12);
    font-size: var(--text-eyebrow);
    color: var(--color-bark);
  }
  .book__note {
    margin: 0;
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-saddle);
  }
</style>
