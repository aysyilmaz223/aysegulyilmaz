---
interface Props {
  ad: string;
  yazar: string;
  not?: string;
  kapak?: string;
}
const { ad, yazar, not, kapak } = Astro.props;
---

<article class="book">
  <div class="book__cover">
    {
      kapak ? (
        <img src={kapak} alt={`${ad} kapağı`} loading="lazy" />
      ) : (
        <span class="book__placeholder meta">{ad}</span>
      )
    }
  </div>
  <div class="book__info">
    <h3 class="book__title">{ad}</h3>
    <p class="book__author meta">{yazar}</p>
    {not && <p class="book__note">{not}</p>}
  </div>
</article>

<style>
  .book {
    display: flex;
    gap: var(--spacing-16);
    padding: var(--spacing-16);
    border: 1px solid var(--color-pencil-gray);
  }
  .book__cover {
    flex: 0 0 84px;
    width: 84px;
    height: 120px;
    border: 1px solid var(--color-pencil-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .book__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .book__placeholder {
    padding: var(--spacing-8);
  }
  .book__info {
    min-width: 0;
  }
  .book__title {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 2px;
  }
  .book__author {
    margin: 0 0 var(--spacing-8);
  }
  .book__note {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-ink-black);
  }
</style>
