---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { trTarih } from '../../utils/tarih';
import { withBase } from '../../utils/url';

const girdiler = (await getCollection('ida')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Ida'nın Güncesi"
  description="Labrador’um Ida ile günlerimizden küçük notlar."
>
  <PageHeader
    eyebrow="Galeri"
    title="Ida’nın Güncesi"
    subtitle="Labrador’um Ida ile günlerimizden küçük, sıcak notlar. 🐾"
  />

  <ul class="gunce">
    {
      girdiler.map((g) => (
        <li>
          <a class={g.data.foto ? 'gunce__item has-foto' : 'gunce__item'} href={withBase(`/idanin-guncesi/${g.id}`)}>
            {g.data.foto && (
              <div class="gunce__foto">
                <img src={withBase(g.data.foto)} alt={g.data.title} loading="lazy" />
              </div>
            )}
            <div class="gunce__body">
              <time class="meta">{trTarih(g.data.date)}</time>
              <span class="gunce__title">{g.data.title}</span>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .gunce {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 720px;
    border-top: 1px solid var(--color-pencil-gray);
  }
  .gunce__item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-16);
    align-items: center;
    padding: var(--spacing-16) 0;
    border-bottom: 1px solid var(--color-pencil-gray);
    color: var(--color-ink-black);
  }
  .gunce__item.has-foto {
    grid-template-columns: 140px 1fr;
  }
  .gunce__foto {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }
  .gunce__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }
  .gunce__item:hover .gunce__foto img {
    opacity: 0.85;
  }
  .gunce__title {
    display: block;
    margin-top: var(--spacing-4);
    font-size: 14px;
    font-weight: 500;
  }
  @media (max-width: 540px) {
    .gunce__item {
      grid-template-columns: 1fr;
    }
  }
</style>
