---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { trTarih } from '../../utils/tarih';
import { withBase } from '../../utils/url';

const girdiler = (await getCollection('ida')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Ida'nın Güncesi"
  description="Labrador’um Ida ile günlerimizden küçük notlar."
>
  <PageHeader
    eyebrow="Galeri"
    title="Ida’nın Güncesi"
    subtitle="Labrador’um Ida ile günlerimizden küçük, sıcak notlar. 🐾"
  />

  <section class="section">
    <div class="container">
      <div class="gunce">
        {
          girdiler.map((g) => (
            <a class="gunce__item" href={withBase(`/idanin-guncesi/${g.id}`)}>
              {g.data.foto && (
                <div class="gunce__foto">
                  <img src={withBase(g.data.foto)} alt={g.data.title} loading="lazy" />
                </div>
              )}
              <div class="gunce__body">
                <time class="card__meta">{trTarih(g.data.date)}</time>
                <h3 class="card__title">{g.data.title}</h3>
                <span class="link-arrow">Devamı →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .gunce {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 760px;
  }
  .gunce__item {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 22px;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: #fff;
    transition: transform 0.25s ease, box-shadow 0.25s ease,
      border-color 0.25s ease;
  }
  .gunce__item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--line-strong);
  }
  .gunce__foto {
    align-self: stretch;
    min-height: 130px;
    overflow: hidden;
  }
  .gunce__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .gunce__body {
    padding: 18px 22px 18px 0;
  }
  .gunce__body .card__title {
    margin: 4px 0 10px;
  }
  @media (max-width: 540px) {
    .gunce__item {
      grid-template-columns: 1fr;
    }
    .gunce__foto {
      aspect-ratio: 16 / 9;
    }
    .gunce__body {
      padding: 0 20px 20px;
    }
  }
</style>
