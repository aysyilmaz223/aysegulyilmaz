---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { withBase } from '../utils/url';

const satirlar = [
  'Benim için yazmak kendimi ifade etmek demek.',
  'Paylaşmak. Gördüklerimi, okuduklarımı, hayallerimi paylaşmak.',
  'Anlatacaklarımı, anlatamadıklarımı dile getirmek.',
  'Özgürlük. Mutluluk.',
  'Yazmak bazen söylemeye cesaret edemediklerimin dışa vurumudur.',
  'Konuşacak kimse bulamadığımda en iyi dosttur. Dertleşmektir.',
  'Hayal kurmaktır. Büyülü bir dünyaya adım atmaktır. Okumayı daha da keyifli kılandır.',
  'Yazmak büyük bir güçtür: Hikâyene istediğin gibi şekil verebileceğinin, istediğin sona varabileceğinin en güzel kanıtıdır.',
];
---

<BaseLayout
  title="Neden Yazıyorum"
  description="Yazmak benim için kendimi ifade etmek, paylaşmak ve iyileşmek."
>
  <PageHeader eyebrow="Hakkımda" title="Neden Yazıyorum?" />

  <article class="section">
    <div class="container">
      <div class="yan-duzen">
        <figure class="yan-foto">
          <img src={withBase('/images/neden.jpg')} alt="Neden yazıyorum" loading="lazy" />
        </figure>
        <div class="yan-icerik">
          <ul class="neden">
            {satirlar.map((s) => <li>{s}</li>)}
          </ul>
          <p class="kapanis">Yazmak iyileştirir.</p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .yan-duzen {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: var(--spacing-40);
    align-items: start;
    max-width: 980px;
    margin: 0 auto;
  }
  .yan-foto {
    background: var(--color-pure-white);
    border: 1px solid var(--color-loam);
    padding: 7px;
  }
  .yan-foto img {
    width: 100%;
    height: auto;
  }
  .neden {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  @media (max-width: 640px) {
    .yan-duzen {
      grid-template-columns: 1fr;
    }
    .yan-foto {
      max-width: 280px;
    }
  }
  .neden li {
    font-size: var(--text-body);
    line-height: 1.5;
    color: var(--color-ink-black);
    padding: var(--spacing-16) 0;
    border-bottom: 1px solid var(--color-pencil-gray);
  }
  .kapanis {
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-ink-black);
    margin-top: var(--spacing-32);
  }
</style>
