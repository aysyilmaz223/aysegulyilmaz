---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import fotograflar from '../data/fotograflar.json';
import { withBase } from '../utils/url';

const seyahatler = await getCollection('seyahatler');
const ida = await getCollection('ida');

type Tile = { src: string; caption: string; cat: string; href: string };
const tiles: Tile[] = [];

fotograflar.forEach((f) =>
  tiles.push({
    src: withBase(f.src),
    caption: f.caption || '',
    cat: 'foto',
    href: withBase('/yazdiran-fotograflar'),
  })
);
seyahatler.forEach((g) => {
  if (g.data.kapak)
    tiles.push({
      src: withBase(g.data.kapak),
      caption: g.data.title,
      cat: 'seyahat',
      href: withBase(`/seyahatler/${g.id}`),
    });
});
ida.forEach((g) => {
  if (g.data.foto)
    tiles.push({
      src: withBase(g.data.foto),
      caption: g.data.title,
      cat: 'ida',
      href: withBase(`/idanin-guncesi/${g.id}`),
    });
});

const tabs = [
  { id: 'all', label: 'Hepsi' },
  { id: 'foto', label: 'Fotoğraflar' },
  { id: 'seyahat', label: 'Seyahatler' },
  { id: 'ida', label: "Ida'nın Güncesi" },
];
---

<BaseLayout
  title="Ayşegül Yılmaz"
  description="Ayşegül Yılmaz — koç, hikâye anlatıcısı, gezgin. Fotoğraflar, seyahatler ve Ida’nın güncesinden bir galeri duvarı."
>
  <nav class="tabs" aria-label="Galeri filtresi">
    {
      tabs.map((t, i) => (
        <button
          class={i === 0 ? 'tab is-active' : 'tab'}
          data-filter={t.id}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          {t.label}
        </button>
      ))
    }
  </nav>

  <div class="wall" id="wall">
    {
      tiles.map((tile) => (
        <a class="tile" href={tile.href} data-cat={tile.cat}>
          <img src={tile.src} alt={tile.caption} loading="lazy" />
          {tile.caption && <span class="tile__cap meta">{tile.caption}</span>}
        </a>
      ))
    }
  </div>
</BaseLayout>

<style>
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-16);
    padding-bottom: var(--spacing-12);
    margin-bottom: var(--spacing-32);
    border-bottom: 1px solid var(--color-pencil-gray);
  }
  .tab {
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-inter);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-graphite);
    transition: color 0.15s ease;
  }
  .tab:hover {
    color: var(--color-ink-black);
  }
  .tab.is-active {
    color: var(--color-ink-black);
  }

  .wall {
    column-count: 3;
    column-gap: var(--spacing-16);
  }
  .tile {
    display: block;
    margin: 0 0 var(--spacing-32);
    break-inside: avoid;
    color: var(--color-ink-black);
  }
  .tile img {
    width: 100%;
    height: auto;
    transition: opacity 0.2s ease;
  }
  .tile:hover img {
    opacity: 0.85;
  }
  .tile__cap {
    display: block;
    margin-top: var(--spacing-8);
  }
  .tile[hidden] {
    display: none;
  }

  @media (max-width: 760px) {
    .wall {
      column-count: 2;
    }
  }
  @media (max-width: 460px) {
    .wall {
      column-count: 1;
    }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const tiles = document.querySelectorAll<HTMLElement>('.tile');

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const filter = tab.dataset.filter;
      tabs.forEach((t) => {
        const on = t === tab;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-pressed', on ? 'true' : 'false');
      });
      tiles.forEach((tile) => {
        const show = filter === 'all' || tile.dataset.cat === filter;
        tile.hidden = !show;
      });
    });
  });
</script>
