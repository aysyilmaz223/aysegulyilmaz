---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';

const bolumler = [
  {
    href: '/ben-kimim',
    baslik: 'Ben Kimim',
    metin: 'Ankara’dan İstanbul’a, insan kaynaklarından koçluğa ve yazıya uzanan bir hikâye.',
  },
  {
    href: '/nasil-yazmaya-basladim',
    baslik: 'Nasıl Yazmaya Başladım',
    metin: 'Günlüklerden bloga, bloglardan Yazı Evi’ne uzanan yol.',
  },
  {
    href: '/neden-yaziyorum',
    baslik: 'Neden Yazıyorum',
    metin: 'Yazmak benim için kendimi ifade etmek, paylaşmak ve iyileşmek.',
  },
  {
    href: '/yazdiklarim',
    baslik: 'Yazdıklarım',
    metin: 'Denemeler, öyküler, anılar — beni ben yapan renkler.',
  },
  {
    href: '/okuduklarim',
    baslik: 'Okuduklarım',
    metin: 'Okuduğum, bana iz bırakan kitaplar ve notlar.',
  },
  {
    href: '/yazdiran-fotograflar',
    baslik: 'Yazdıran Fotoğraflar',
    metin: 'Bana bir şeyler anlattıran, yazmaya iten kareler.',
  },
  {
    href: '/dusunduren-sozler',
    baslik: 'Düşündüren Sözler',
    metin: 'Aklımda kalan, üzerine düşündüğüm sözler.',
  },
  {
    href: '/idanin-guncesi',
    baslik: 'Ida’nın Güncesi',
    metin: 'Labrador’um Ida ile günlerimizden küçük notlar. 🐾',
  },
  {
    href: '/seyahatler',
    baslik: 'Seyahatler',
    metin: 'Gezdiğim, gördüğüm yerler ve onların hissettirdikleri.',
  },
];
---

<BaseLayout
  title="Ayşegül Yılmaz"
  description="Ayşegül Yılmaz — koç, hikâye anlatıcısı, gezgin. Yazılar, okumalar, fotoğraflar, seyahatler ve Ida’nın güncesi."
>
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="eyebrow">Koç · Yazar · Gezgin</p>
        <h1>Merhaba, ben Ayşegül.</h1>
        <p class="hero__lead">
          Hikâye anlatıcısı, gezgin, doğa ve Labrador sevdalısı, Ida’nın
          annesi. Burada yazdıklarımı, okuduklarımı, fotoğraflarımı ve
          yollarda biriktirdiklerimi bir araya getirdim.
        </p>
        <div class="hero__actions">
          <a class="btn btn--primary" href={withBase('/ben-kimim')}>Ben Kimim</a>
          <a class="btn" href={withBase('/yazdiklarim')}>Yazdıklarım</a>
          <a class="btn" href="https://aysegulyilmaz.blogspot.com/" target="_blank" rel="noopener">Blog ↗</a>
        </div>
      </div>
      <div class="hero__media">
        <img src={withBase('/images/profil.jpg')} alt="Ayşegül Yılmaz" />
      </div>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container">
      <p class="eyebrow">Bölümler</p>
      <h2 class="sectionhead">Ne bulacaksın?</h2>
      <div class="grid grid--3 bolumler">
        {
          bolumler.map((b) => (
            <a class="card bolum" href={withBase(b.href)}>
              <div class="card__body">
                <h3 class="card__title">{b.baslik}</h3>
                <p class="card__excerpt">{b.metin}</p>
                <span class="bolum__more link-arrow">Aç →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: clamp(48px, 8vw, 96px) 0 clamp(40px, 6vw, 72px);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
  }
  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    margin-bottom: 0.3em;
  }
  .hero__lead {
    font-size: 1.2rem;
    line-height: 1.6;
    color: #3a382f;
    max-width: 46ch;
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }
  .hero__media img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 18px;
    box-shadow: var(--shadow);
  }

  .section--soft {
    background: var(--bg-soft);
    border-top: 1px solid var(--line);
  }
  .sectionhead {
    margin-bottom: 36px;
  }
  .bolum {
    display: block;
  }
  .bolum__more {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.92rem;
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__media {
      order: -1;
      max-width: 320px;
    }
  }
</style>
