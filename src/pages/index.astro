---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';

const kolaj = [
  { src: '/images/foto-7.jpg', rot: -3 },
  { src: '/images/foto-9.jpg', rot: 2 },
  { src: '/images/foto-8.jpg', rot: -1.5 },
  { src: '/images/foto-4.jpg', rot: 2.5 },
  { src: '/images/foto-5.jpg', rot: -2 },
];

const bolumler = [
  {
    href: '/ben-kimim',
    label: 'Ben Kimim',
    icon: '<circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.6-6.5 8-6.5S20 17 20 21"/>',
  },
  {
    href: '/nasil-yazmaya-basladim',
    label: 'Nasıl Yazmaya Başladım',
    icon: '<path d="M4 20l1-4L16 5l3 3L8 19l-4 1z"/><path d="M14 7l3 3"/>',
  },
  {
    href: '/neden-yaziyorum',
    label: 'Neden Yazıyorum',
    icon: '<path d="M12 20s-7-4.3-7-9a4 4 0 0 1 7-2.6A4 4 0 0 1 19 11c0 4.7-7 9-7 9z"/>',
  },
  {
    href: '/yazdiklarim',
    label: 'Yazdıklarım',
    icon: '<rect x="5" y="3" width="14" height="18" rx="1.5"/><path d="M8 8h8M8 12h8M8 16h5"/>',
  },
  {
    href: '/okuduklarim',
    label: 'Okuduklarım',
    icon: '<path d="M12 6c-1.8-1.3-4-2-7-2v14c3 0 5.2.7 7 2 1.8-1.3 4-2 7-2V4c-3 0-5.2.7-7 2z"/><path d="M12 6v14"/>',
  },
  {
    href: '/dusunduren-sozler',
    label: 'Düşündüren Sözler',
    icon: '<path d="M9 7C6.5 7 5 9 5 11.5S6.5 15 8.5 15c.3 2-1 3.3-2.5 4 3.5-.3 6-2.8 6-6.5C12 9 11 7 9 7zM18 7c-2.5 0-4 2-4 4.5S15.5 15 17.5 15c.3 2-1 3.3-2.5 4 3.5-.3 6-2.8 6-6.5C21 9 20 7 18 7z"/>',
  },
  {
    href: '/yazdiran-fotograflar',
    label: 'Yazdıran Fotoğraflar',
    icon: '<path d="M4 8h3l1.5-2h7L17 8h3v11H4z"/><circle cx="12" cy="13" r="3.2"/>',
  },
  {
    href: '/seyahatler',
    label: 'Seyahatler',
    icon: '<circle cx="12" cy="12" r="8"/><path d="M15 9l-2 4-4 2 2-4 4-2z"/>',
  },
  {
    href: '/idanin-guncesi',
    label: "Ida'nın Güncesi",
    icon: '<ellipse cx="12" cy="15" rx="4" ry="3"/><circle cx="7" cy="9" r="1.6"/><circle cx="17" cy="9" r="1.6"/><circle cx="9.5" cy="6.5" r="1.4"/><circle cx="14.5" cy="6.5" r="1.4"/>',
  },
];
---

<BaseLayout
  title="Ayşegül Yılmaz"
  description="Ayşegül Yılmaz — koç, hikâye anlatıcısı, gezgin. Yazılar, okumalar, fotoğraflar, seyahatler ve Ida’nın güncesi."
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Koç · Hikâye Anlatıcısı · Gezgin</p>
      <h1 class="hero__title">Yazıyorum, paylaşıyorum, iyileşiyorum.</h1>
      <p class="hero__lead">
        Merhaba, ben Ayşegül. Doğa ve Labrador sevdalısı, Ida’nın annesi.
        Burada yazdıklarımı, okuduklarımı, fotoğraflarımı ve yollarda
        biriktirdiklerimi bir araya getirdim.
      </p>
      <div class="hero__actions">
        <a class="btn btn--primary" href={withBase('/yazdiklarim')}>Yazdıklarım →</a>
        <a class="btn btn--ghost" href={withBase('/ben-kimim')}>Ben Kimim</a>
      </div>
    </div>
  </section>

  <!-- Belgesel fotoğraf kolajı -->
  <section class="collage" aria-label="Fotoğraflar">
    {
      kolaj.map((p) => (
        <div class="collage__item" style={`--rot:${p.rot}deg`}>
          <img src={withBase(p.src)} alt="" loading="lazy" />
        </div>
      ))
    }
  </section>

  <!-- Bölümler -->
  <section class="section">
    <div class="container">
      <div class="sectionhead">
        <p class="eyebrow">Bölümler</p>
        <h2>Ne bulacaksın?</h2>
      </div>
      <div class="bolumler">
        {
          bolumler.map((b) => (
            <a class="bolum" href={withBase(b.href)}>
              <svg class="bolum__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={b.icon} />
              <span class="bolum__label">
                {b.label} <span class="bolum__arrow">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Koyu alıntı paneli -->
  <section class="section">
    <div class="container">
      <div class="panel">
        <div class="panel__text">
          <p class="eyebrow panel__eyebrow">Neden Yazıyorum</p>
          <blockquote class="panel__quote">“Yazmak iyileştirir.”</blockquote>
          <p class="panel__sub">
            Benim için yazmak kendimi ifade etmek, paylaşmak ve söylemeye cesaret
            edemediklerimi dile getirmek demek.
          </p>
          <a class="btn btn--primary" href={withBase('/neden-yaziyorum')}>Devamını oku →</a>
        </div>
        <div class="panel__media">
          <img src={withBase('/images/foto-8.jpg')} alt="Ayşegül ve Ida" loading="lazy" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* hero */
  .hero {
    text-align: center;
    padding: clamp(48px, 8vw, 96px) 0 clamp(32px, 5vw, 56px);
  }
  .hero__title {
    font-size: clamp(38px, 6.5vw, 68px);
    line-height: 1.03;
    letter-spacing: -0.02em;
    max-width: 16ch;
    margin: 0 auto;
  }
  .hero__lead {
    max-width: 56ch;
    margin: var(--spacing-20) auto 0;
    font-size: var(--text-body-lg);
    line-height: 1.6;
    color: var(--color-saddle);
  }
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-12);
    justify-content: center;
    margin-top: var(--spacing-32);
  }

  /* kolaj */
  .collage {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0;
    padding: var(--spacing-20) 16px var(--spacing-40);
    max-width: 1100px;
    margin: 0 auto;
  }
  .collage__item {
    background: var(--color-pure-white);
    border: 1px solid var(--color-loam);
    padding: 7px;
    transform: rotate(var(--rot));
    margin: 0 -10px;
    transition: transform 0.25s ease, z-index 0.25s;
    box-shadow: 0 1px 0 rgba(33, 27, 21, 0.04);
  }
  .collage__item:hover {
    transform: rotate(0deg) scale(1.03);
    z-index: 5;
    position: relative;
  }
  .collage__item img {
    width: clamp(140px, 19vw, 215px);
    height: clamp(180px, 24vw, 270px);
    object-fit: cover;
  }

  /* bölüm başlığı */
  .sectionhead {
    text-align: center;
    margin-bottom: var(--spacing-40);
  }

  /* bölüm ızgarası — ince çizgi hücreler, çizgi-ikon */
  .bolumler {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-bone);
    border-left: 1px solid var(--color-bone);
  }
  .bolum {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-16);
    padding: var(--spacing-40) var(--spacing-20);
    border-right: 1px solid var(--color-bone);
    border-bottom: 1px solid var(--color-bone);
    color: var(--color-ink);
    transition: background 0.15s ease;
  }
  .bolum:hover {
    background: var(--color-bone);
    color: var(--color-ink);
  }
  .bolum__icon {
    width: 40px;
    height: 40px;
    color: var(--color-ink);
  }
  .bolum__label {
    font-size: var(--text-body);
    font-weight: 500;
  }
  .bolum__arrow {
    color: var(--color-saddle);
  }

  /* koyu panel */
  .panel {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: center;
    background: var(--color-charcoal-olive);
    border-radius: var(--radius-card);
    padding: clamp(28px, 4vw, 56px);
  }
  .panel__eyebrow {
    color: var(--color-wheat);
  }
  .panel__quote {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.15;
    color: var(--color-parchment);
    margin: 0 0 var(--spacing-20);
    letter-spacing: -0.011em;
  }
  .panel__sub {
    color: var(--color-bone);
    font-size: var(--text-body-lg);
    max-width: 46ch;
    margin: 0 0 var(--spacing-32);
  }
  .panel__media {
    background: var(--color-pure-white);
    border: 1px solid var(--color-loam);
    padding: 8px;
    transform: rotate(1.5deg);
  }
  .panel__media img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  @media (max-width: 760px) {
    .bolumler {
      grid-template-columns: repeat(2, 1fr);
    }
    .panel {
      grid-template-columns: 1fr;
    }
    .panel__media {
      order: -1;
      max-width: 280px;
    }
  }
  @media (max-width: 460px) {
    .bolumler {
      grid-template-columns: 1fr;
    }
  }
</style>
