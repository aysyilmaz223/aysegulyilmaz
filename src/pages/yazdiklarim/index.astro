---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { trTarih } from '../../utils/tarih';
import { withBase } from '../../utils/url';

const yazilar = (await getCollection('yazdiklarim')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Yazdıklarım"
  description="Denemeler, öyküler, anılar — beni ben yapan renkler."
>
  <PageHeader
    eyebrow="Yazılar"
    title="Yazdıklarım"
    subtitle="Denemeler, öyküler, kurgular, anılar… Beni ben yapan renkler."
  />

  <ul class="list">
    {
      yazilar.map((yazi) => (
        <li>
          <a class="row" href={withBase(`/yazdiklarim/${yazi.id}`)}>
            <span class="row__meta meta">
              {yazi.data.tur ? `${yazi.data.tur} · ` : ''}
              {trTarih(yazi.data.date)}
            </span>
            <span class="row__title">{yazi.data.title}</span>
            {yazi.data.description && (
              <span class="row__desc meta">{yazi.data.description}</span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>

<style>
  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: var(--prose-w);
    border-top: 1px solid var(--color-pencil-gray);
  }
  .row {
    display: block;
    padding: var(--spacing-16) 0;
    border-bottom: 1px solid var(--color-pencil-gray);
  }
  .row__meta {
    display: block;
    margin-bottom: var(--spacing-4);
  }
  .row__title {
    display: block;
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-ink-black);
  }
  .row:hover .row__title {
    color: var(--color-smoke);
  }
  .row__desc {
    display: block;
    margin-top: var(--spacing-4);
  }
</style>
