---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { trTarih } from '../../utils/tarih';
import { withBase } from '../../utils/url';

export async function getStaticPaths() {
  const yazilar = await getCollection('yazdiklarim');
  return yazilar.map((yazi) => ({
    params: { slug: yazi.id },
    props: { yazi },
  }));
}

const { yazi } = Astro.props;
const { Content } = await render(yazi);
---

<BaseLayout title={yazi.data.title} description={yazi.data.description}>
  <article class="section">
    <div class="container">
      <p class="back"><a class="link-arrow" href={withBase('/yazdiklarim')}>← Yazdıklarım</a></p>
      <header class="yazi-head">
        <p class="meta">
          {yazi.data.tur ? `${yazi.data.tur} · ` : ''}{trTarih(yazi.data.date)}
        </p>
        <h1>{yazi.data.title}</h1>
      </header>
      <div class="prose yazi-icerik">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .back {
    margin-bottom: 24px;
  }
  .yazi-head {
    max-width: var(--prose-w);
    margin-bottom: var(--spacing-32);
    padding-bottom: var(--spacing-20);
    border-bottom: 1px solid var(--color-pencil-gray);
  }
  .yazi-head h1 {
    margin-top: var(--spacing-8);
  }
  .yazi-icerik :global(blockquote) {
    border-left: 1px solid var(--color-pencil-gray);
    padding-left: var(--spacing-16);
    margin: 1.4em 0;
    color: var(--color-graphite);
  }
</style>
