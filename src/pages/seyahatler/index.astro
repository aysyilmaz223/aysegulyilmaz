---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { trTarih } from '../../utils/tarih';
import { withBase } from '../../utils/url';

const geziler = (await getCollection('seyahatler')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout
  title="Seyahatler"
  description="Gezdiğim, gördüğüm yerler ve onların hissettirdikleri."
>
  <PageHeader
    eyebrow="Galeri"
    title="Seyahatler"
    subtitle="Gezdiğim, gördüğüm yerleri ve onların bana hissettirdiklerini fotoğraflarla anlatıyorum."
  />

  <div class="grid">
    {
      geziler.map((gezi) => (
        <a class="gezi" href={withBase(`/seyahatler/${gezi.id}`)}>
          {gezi.data.kapak && (
            <img src={withBase(gezi.data.kapak)} alt={gezi.data.title} loading="lazy" />
          )}
          <span class="gezi__meta meta">
            {gezi.data.yer ? `${gezi.data.yer} · ` : ''}
            {trTarih(gezi.data.date)}
          </span>
          <span class="gezi__title">{gezi.data.title}</span>
          {gezi.data.description && (
            <span class="gezi__desc meta">{gezi.data.description}</span>
          )}
        </a>
      ))
    }
  </div>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-32) var(--spacing-16);
  }
  .gezi {
    display: block;
    color: var(--color-ink-black);
  }
  .gezi img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    transition: opacity 0.2s ease;
  }
  .gezi:hover img {
    opacity: 0.85;
  }
  .gezi__meta {
    display: block;
    margin: var(--spacing-8) 0 2px;
  }
  .gezi__title {
    display: block;
    font-size: 14px;
    font-weight: 500;
  }
  .gezi__desc {
    display: block;
    margin-top: var(--spacing-4);
  }
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
