---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import geziler from '../../data/seyahat-yazilari.json';

const blogMagazine = 'https://aysegulyilmaz.blogspot.com/?view=magazine';
---

<BaseLayout
  title="Seyahatler"
  description="Gezdiğim, gördüğüm yerler ve onların hissettirdikleri — blogumdaki gezi yazılarım."
>
  <PageHeader
    eyebrow="Yazılar"
    title="Seyahatler"
    subtitle="Gezdiğim yerleri ve onların bana hissettirdiklerini blogumda yazıyorum. Aşağıdaki gezilerden birine tıklayınca yazıların tamamı blogumda açılır."
  />

  <section class="section">
    <div class="container">
      <div class="grid">
        {
          geziler.map((gezi) => (
            <a class="gezi" href={gezi.url} target="_blank" rel="noopener">
              {gezi.kapak && (
                <div class="gezi__cover">
                  <img
                    src={gezi.kapak}
                    alt={gezi.baslik}
                    loading="lazy"
                    referrerpolicy="no-referrer"
                  />
                </div>
              )}
              <span class="gezi__meta meta">{gezi.tarih}</span>
              <span class="gezi__title">{gezi.baslik} <span class="gezi__arrow">↗</span></span>
              {gezi.aciklama && <span class="gezi__desc">{gezi.aciklama}</span>}
            </a>
          ))
        }
      </div>

      <p class="tumu">
        <a class="link-arrow" href={blogMagazine} target="_blank" rel="noopener">
          Tüm gezi yazılarım blogumda →
        </a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-40) var(--spacing-32);
  }
  .gezi {
    display: block;
    color: var(--color-ink);
  }
  .gezi__cover {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 1px solid var(--color-loam);
    border-radius: var(--radius-card);
    background: var(--color-bone);
  }
  .gezi__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .gezi:hover .gezi__cover img {
    transform: scale(1.03);
  }
  .gezi__meta {
    display: block;
    margin: var(--spacing-16) 0 4px;
  }
  .gezi__title {
    display: block;
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.011em;
  }
  .gezi__arrow {
    color: var(--color-saddle);
    font-size: 17px;
  }
  .gezi__desc {
    display: block;
    margin-top: var(--spacing-8);
    font-size: var(--text-body);
    color: var(--color-saddle);
  }
  .tumu {
    margin-top: var(--spacing-40);
    padding-top: var(--spacing-20);
    border-top: 1px solid var(--color-bone);
  }
  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
