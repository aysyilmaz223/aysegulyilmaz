---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import BookCard from '../components/BookCard.astro';
import kitaplar from '../data/okuduklarim.json';
import { withBase } from '../utils/url';
---

<BaseLayout
  title="Okuduklarım"
  description="Okuduğum, bana iz bırakan kitaplar ve kısa notlar."
>
  <PageHeader
    eyebrow="Kitaplık"
    title="Okuduklarım"
    subtitle="Okuduğum, bana bir şey katan kitaplar ve onlara dair notlarım."
  />

  <section class="section">
    <div class="container">
      <figure class="lead-foto">
        <img src={withBase('/images/okuduklarim.jpg')} alt="Okuduklarım" loading="lazy" />
      </figure>
      <div class="cols2">
        {
          kitaplar.map((k) => (
            <BookCard ad={k.ad} yazar={k.yazar} not={k.not} kapak={k.kapak ? withBase(k.kapak) : ''} />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lead-foto {
    margin: 0 auto var(--spacing-60);
    max-width: 480px;
    background: var(--color-pure-white);
    border: 1px solid var(--color-loam);
    padding: 8px;
  }
  .lead-foto img {
    width: 100%;
    height: auto;
  }
</style>
