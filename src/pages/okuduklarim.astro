---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import kitaplar from '../data/okuduklarim.json';
import { withBase } from '../utils/url';
---

<BaseLayout
  title="Okuduklarım"
  description="Okuduğum, bana iz bırakan kitaplar ve kısa notlar."
>
  <PageHeader
    eyebrow="Kitaplık"
    title="Okuduklarım"
    subtitle="Okuduğum, bana bir şey katan kitaplar ve onlara dair notlarım."
  />

  <section class="section">
    <div class="container">
      <figure class="lead-foto">
        <img src={withBase('/images/okuduklarim.jpg')} alt="Okuduklarım" loading="lazy" />
      </figure>

      <ul class="kitaplar">
        {
          kitaplar.map((k) => (
            <li class="kitap">
              <div class="kitap__kapak">
                {k.kapak ? (
                  <img src={withBase(k.kapak)} alt={`${k.ad} kapağı`} loading="lazy" />
                ) : (
                  <span>{k.ad}</span>
                )}
              </div>
              <div class="kitap__govde">
                <h3 class="kitap__ad">{k.ad}</h3>
                <p class="kitap__meta">
                  <span>{k.yazar}</span>
                  {k.yil && <span class="ayrac"> · {k.yil}</span>}
                  {k.puan > 0 && (
                    <span class="kitap__puan"> · {'★'.repeat(k.puan)}{'☆'.repeat(5 - k.puan)}</span>
                  )}
                </p>
                {k.not && <p class="kitap__not">{k.not}</p>}
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .lead-foto {
    margin: 0 auto var(--spacing-60);
    max-width: 480px;
    background: var(--color-pure-white);
    border: 1px solid var(--color-loam);
    padding: 8px;
  }
  .lead-foto img {
    width: 100%;
    height: auto;
  }

  .kitaplar {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 760px;
    border-top: 1px solid var(--color-bone);
  }
  .kitap {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--spacing-20);
    padding: var(--spacing-20) 0;
    border-bottom: 1px solid var(--color-bone);
  }
  .kitap__kapak {
    width: 64px;
    height: 92px;
    border: 1px solid var(--color-loam);
    border-radius: var(--radius-control);
    background: var(--color-bone);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .kitap__kapak img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .kitap__kapak span {
    font-family: var(--font-display);
    font-size: 11px;
    line-height: 1.3;
    color: var(--color-saddle);
    padding: 4px;
  }
  .kitap__ad {
    font-size: 19px;
    margin: 0 0 3px;
  }
  .kitap__meta {
    font-size: var(--text-eyebrow);
    color: var(--color-bark);
    margin: 0 0 var(--spacing-8);
  }
  .kitap__puan {
    color: var(--color-saddle);
    letter-spacing: 1px;
  }
  .kitap__not {
    font-size: var(--text-body);
    line-height: 1.6;
    color: var(--color-saddle);
    margin: 0;
  }

  @media (max-width: 480px) {
    .kitap {
      grid-template-columns: 52px 1fr;
      gap: var(--spacing-16);
    }
    .kitap__kapak {
      width: 52px;
      height: 74px;
    }
  }
</style>
