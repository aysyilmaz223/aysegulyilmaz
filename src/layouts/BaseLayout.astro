---
import Sidebar from '../components/Sidebar.astro';
import { withBase } from '../utils/url';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ayşegül Yılmaz',
  description = 'Ayşegül Yılmaz — koç, hikâye anlatıcısı, gezgin. Yazılar, okumalar, fotoğraflar, seyahatler ve Ida’nın güncesi.',
} = Astro.props;

const fullTitle = title === 'Ayşegül Yılmaz' ? title : `${title} — Ayşegül Yılmaz`;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#icerik" class="visually-hidden">İçeriğe atla</a>
    <div class="layout">
      <Sidebar />
      <main id="icerik" class="well">
        <slot />
      </main>
    </div>
  </body>
</html>
