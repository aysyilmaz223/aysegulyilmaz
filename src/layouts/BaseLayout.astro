---
import TopNav from '../components/TopNav.astro';
import Footer from '../components/Footer.astro';
import { withBase } from '../utils/url';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Ayşegül Yılmaz',
  description = 'Ayşegül Yılmaz — koç, hikâye anlatıcısı, gezgin. Yazılar, okumalar, fotoğraflar, seyahatler ve Ida’nın güncesi.',
  image = '/images/profil.jpg',
} = Astro.props;

const fullTitle = title === 'Ayşegül Yılmaz' ? title : `${title} — Ayşegül Yılmaz`;

// Üretim alan adı: canonical/og her zaman buraya işaret eder (iki yayın da
// aynı içeriği sunduğu için yinelenen içeriği önler).
const PROD = 'https://aysegulyaziyor.com';
// Astro.url.pathname GitHub derlemesinde base'i içerir; onu çıkarıp tek slash kök yola çevir.
const base = import.meta.env.BASE_URL.replace(/\/$/, ''); // '/aysegulyilmaz' veya ''
let cleanPath = Astro.url.pathname;
if (base && cleanPath.startsWith(base)) cleanPath = cleanPath.slice(base.length);
if (!cleanPath.startsWith('/')) cleanPath = '/' + cleanPath;
const canonical = PROD + cleanPath;
const ogImage = PROD + image;

// Cloudflare dışı yayınlar (GitHub Pages/yerel) noindex — sadece aysegulyaziyor.com indekslensin.
const indexable = !!import.meta.env.CF_PAGES || !!process.env.CF_PAGES;

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Ayşegül Yılmaz',
    url: PROD,
    jobTitle: 'Yazar, Koç',
    sameAs: [
      'https://www.instagram.com/aysegulyy/',
      'https://aysegulyilmaz.blogspot.com/',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Ayşegül Yılmaz',
    url: PROD,
    inLanguage: 'tr',
  },
];
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {!indexable && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Ayşegül Yılmaz" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a href="#icerik" class="visually-hidden">İçeriğe atla</a>
    <TopNav />
    <main id="icerik">
      <slot />
    </main>
    <Footer />
  </body>
</html>
